---
const attributes = ["Personalización", "Decoración", "Puntualidad", "Diversión"];
---

<div class="relative py-16 overflow-hidden bg-gray-900 isolate sm:py-24 md:py-32">
  <!-- Decorative background image -->
  <img
    src="/image/fotito.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 object-cover object-right w-full h-full -z-10 md:object-center"
  />

  <!-- Decorative gradient blobs -->
  <div
    class="hidden sm:block sm:absolute sm:-top-10 sm:right-1/2 sm:-z-10 sm:mr-10 sm:transform-gpu sm:blur-3xl"
    aria-hidden="true"
  >
    <div class="aspect-[1097/845] w-[40rem] md:w-[68.5625rem] bg-gradient-to-tr from-[#ff4694] to-[#776fff] opacity-20 clip-blob"></div>
  </div>

  <div
    class="absolute -top-36 sm:-top-52 left-1/2 -z-10 -translate-x-1/2 transform-gpu blur-2xl sm:blur-3xl sm:top-[-28rem] sm:ml-16"
    aria-hidden="true"
  >
    <div class="aspect-[1097/845] w-[40rem] md:w-[68.5625rem] bg-gradient-to-tr from-[#ff4694] to-[#776fff] opacity-20 clip-blob"></div>
  </div>

  <div class="max-w-6xl px-6 mx-auto lg:px-8">
    <div class="max-w-2xl mx-auto text-center lg:mx-0 lg:text-left">
      <h2 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-7xl">DECO KIDS</h2>
      <p class="mt-6 text-lg font-medium text-gray-300 text-pretty sm:mt-8 sm:text-xl lg:leading-relaxed">
        En TM Cositas, transformamos cada evento en una experiencia inolvidable llena de magia y
        diversión para los más pequeños. Nuestro compromiso es hacer que cada celebración sea única
        y especial.
      </p>
    </div>

    <div class="max-w-2xl mx-auto mt-8 lg:mx-0 lg:max-w-none">
      <ul class="grid grid-cols-2 text-base font-semibold text-center text-white gap-x-4 gap-y-6 md:text-left sm:grid-cols-2 md:flex md:flex-wrap lg:gap-x-10 lg:text-lg list-none p-0">
        {attributes.map((attr) => (
          <li class="transition-transform duration-300 border-b-4 border-pink-500 hover:scale-110">
            {attr}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  /*
   * Complex polygon clip-path kept in CSS to avoid cluttering the markup.
   * Shape creates an organic blob effect for the decorative gradient backgrounds.
   */
  .clip-blob {
    clip-path: polygon(
      74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%,
      72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%,
      27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%
    );
  }
</style>
