---
import { Image } from "astro:assets";
import { GALLERY_IMAGES } from "@data/images";
import { WHATSAPP_URL } from "@lib/constants";
---

<section class="py-16 bg-white">
  <div class="container px-4 mx-auto">
    <div class="flex flex-col items-center justify-between gap-8 lg:flex-row">
      <div class="space-y-6 lg:w-1/2">
        <h2 class="text-4xl font-bold text-gray-800">Reserva tu evento hoy</h2>
        <p class="text-lg text-gray-600">
          Deja que TM COSITAS haga de tu próxima celebración una experiencia inolvidable.
        </p>
        <p class="text-lg text-gray-600">
          Contáctanos para planificar tu evento con nuestra experta asesoría.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 font-semibold text-white transition-all duration-500 bg-pink-500 rounded-full hover:scale-105 hover:bg-pink-600"
        >
          Reserva Ahora
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-3 lg:w-1/2">
        {GALLERY_IMAGES.map((image) => (
          <Image
            src={image.src}
            alt={image.alt}
            width={300}
            height={200}
            class="transition duration-500 transform rounded-lg shadow-md hover:scale-105"
          />
        ))}
      </div>
    </div>
  </div>
</section>
