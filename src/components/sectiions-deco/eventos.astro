---
import { EVENTS } from "@data/events";
---

<section class="py-16 bg-white">
  <h2 class="w-full pb-2 mb-8 text-4xl font-bold text-center text-gray-800 transition-transform duration-300 hover:scale-110">
    Decoraciones
  </h2>

  <div class="flex flex-col items-center">
    <div class="grid w-full max-w-screen-xl grid-cols-1 gap-8 px-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {EVENTS.map((event) => (
        <div class="relative max-w-full overflow-hidden transform rounded-lg shadow-md">
          <img
            src={event.src}
            alt={event.alt}
            class="object-cover w-full h-[16rem] transition duration-300 hover:scale-110 hover:brightness-75"
          />
          <div class="absolute bottom-0 left-0 p-4 bg-gradient-to-t from-black/60 via-transparent to-transparent">
            <h3 class="text-lg font-semibold text-white transition-all duration-300 shadow-lg">
              {event.title}
            </h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
