---
import { FEATURES } from "@data/features";
---

<section id="caracteristicas" class="py-12 bg-white">
  <div class="container px-4 mx-auto">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((feature) => (
        <div class="flex flex-col items-center p-6 text-center transition-all duration-500 hover:scale-105">
          <div class="flex items-center justify-center p-4 mb-4 bg-pink-100 rounded-full">
            {/* SVG icons are recolored to pink via CSS filter below */}
            <img src={feature.icon} alt={feature.iconAlt} class="w-8 h-8" />
          </div>
          <h3 class="mb-2 text-xl font-semibold text-gray-800">{feature.title}</h3>
          <p class="text-gray-600">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /*
   * Recolors white/black SVG icons to the brand pink (#ec4899 / pink-500).
   * Filter values generated via: https://codepen.io/sosuke/pen/Pjoqqp
   */
  img {
    filter: invert(28%) sepia(91%) saturate(7475%) hue-rotate(320deg) brightness(96%) contrast(106%);
  }
</style>
