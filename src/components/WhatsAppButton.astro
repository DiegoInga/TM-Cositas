---
import { WHATSAPP_URL } from "@lib/constants";
---

<!--
  Floating WhatsApp contact button — fixed to the bottom-right of every page.
  The tooltip appears on hover showing "Contáctanos".
-->
<a
  href={WHATSAPP_URL}
  class="whatsapp-float-container"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <span class="whatsapp-tooltip" aria-hidden="true">Contáctanos</span>
  <div class="whatsapp-float">
    <img src="/icons/whatsapp.svg" alt="" width="50" height="50" aria-hidden="true" />
  </div>
</a>

<style>
  /* WhatsApp brand green: #25D366 / hover: #20b558 */
  .whatsapp-float-container {
    position: fixed;
    bottom: 1.875rem; /* 30px */
    right: 1.875rem;  /* 30px */
    display: flex;
    align-items: center;
    cursor: pointer;
    z-index: 1000;
  }

  .whatsapp-float {
    width: 4.375rem;  /* 70px */
    height: 4.375rem; /* 70px */
    background-color: #25d366;
    border-radius: 50%;
    box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s, transform 0.3s;
  }

  .whatsapp-tooltip {
    visibility: hidden;
    opacity: 0;
    margin-right: 0.625rem; /* 10px */
    padding: 0.5rem 0.75rem;
    background-color: #25d366;
    color: white;
    font-weight: 500;
    border-radius: 0.3125rem;
    font-size: 0.875rem; /* 14px */
    white-space: nowrap;
    transition: opacity 0.3s;
  }

  .whatsapp-float-container:hover .whatsapp-tooltip {
    visibility: visible;
    opacity: 1;
  }

  .whatsapp-float:hover {
    background-color: #20b558;
    transform: scale(1.1);
  }
</style>
